{
  "name": "photovault",
  "version": "1.0.4",
  "description": "Minimalist desktop photo storage and organization",
  "main": "main.js",
  "author": "Devoid2",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "postinstall": "node -e \"if(process.platform==='darwin'){require('child_process').execSync('swiftc build/haptic.swift -o build/haptic 2>/dev/null || true')}\"",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "exifr": "^7.1.3",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.devoid2.photovault",
    "productName": "PhotoVault",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "build/haptic",
          "to": "haptic"
        }
      ],
      "x64ArchFiles": "Contents/Resources/haptic"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Devoid2",
      "repo": "PhotoVault"
    }
  }
}
