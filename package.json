{
  "name": "photovault",
  "version": "1.2.0",
  "description": "Minimalist desktop photo storage and organization",
  "main": "main.js",
  "author": "Devoid2",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.3.9",
    "exifr": "^7.1.3",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.devoid2.photovault",
    "productName": "PhotoVault",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/chokidar/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "build/haptic",
          "to": "haptic"
        }
      ],
      "x64ArchFiles": "**/haptic"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Devoid2",
      "repo": "PhotoVault"
    }
  }
}
